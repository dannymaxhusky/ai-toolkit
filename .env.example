# Copy this into Netlify -> Site settings -> Environment variables.
# For local dev with `netlify dev`, put the real value in a local .env (git-ignored).

# Google AI Studio key — MUST have billing enabled (image models are not free-tier).
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# That's it. Storage (job state + images) uses Netlify Blobs, which is
# provisioned automatically — no database account or extra keys needed.
