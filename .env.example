# Copy these into Netlify -> Site settings -> Environment variables.
# For local dev with `netlify dev`, put real values in a local .env (git-ignored).

# Google AI Studio key — MUST have billing enabled (image models are not free-tier).
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Supabase REST URL, e.g. https://abcdefgh.supabase.co
# Supabase Dashboard -> Project Settings -> API -> Project URL
SUPABASE_URL=

# Supabase service role key (SERVER ONLY — never expose to the browser).
# Supabase Dashboard -> Project Settings -> API -> service_role secret
SUPABASE_SERVICE_ROLE_KEY=
