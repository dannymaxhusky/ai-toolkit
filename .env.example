# Copy this into Netlify -> Site settings -> Environment variables.
# For local dev with `netlify dev`, put the real value in a local .env (git-ignored).

# --- Google (Gemini) model path ---
# Google AI Studio key — MUST have billing enabled (image models are not free-tier).
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Seedance (Seedream image) model path ---
# Bearer token from your seedance2.ai dashboard (sk_live_... or sk_test_...).
# Only needed if you offer the Seedance option in the UI.
SEEDANCE_API_KEY=

# Optional Seedance overrides — set these only if the defaults don't match
# your account's image (Seedream) API. Defaults:
#   SEEDANCE_API_BASE=https://api.seedance2.ai
#   SEEDANCE_IMAGE_ENDPOINT=/v1/images/generations
#   SEEDANCE_IMAGE_MODEL=seedream-4-0
# SEEDANCE_API_BASE=
# SEEDANCE_IMAGE_ENDPOINT=
# SEEDANCE_IMAGE_MODEL=

# Storage (job state + images) uses Netlify Blobs, provisioned automatically —
# no database account needed.
